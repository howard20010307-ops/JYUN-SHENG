# 複製為 .env 後再填。Vite 只會暴露 VITE_ 開頭的變數。

# Firebase（選用）
# VITE_FIREBASE_API_KEY=
# VITE_FIREBASE_AUTH_DOMAIN=
# VITE_FIREBASE_PROJECT_ID=
# VITE_FIREBASE_STORAGE_BUCKET=
# VITE_FIREBASE_MESSAGING_SENDER_ID=
# VITE_FIREBASE_APP_ID=

# JSONBin 全自動雲端備份：在 https://jsonbin.io 註冊 → API Keys 複製 $MASTER_KEY →
# 以 POST /v3/b 建一筆空 Bin 或用網站建立，把 Bin id 與金鑰填在下方，重新 npm run dev。
# 注意：Master Key 會被打進前端 bundle，不適合對外公開的網站。
# VITE_JSONBIN_BIN_ID=
# VITE_JSONBIN_X_MASTER_KEY=
